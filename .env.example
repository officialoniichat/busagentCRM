ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret

# Firebase Admin SDK — only needed in production (Railway).
# Locally, serviceKey.json in the repo root is picked up automatically.
# For Railway, copy the values from your serviceKey.json:
#   project_id      → FIREBASE_PROJECT_ID
#   client_email    → FIREBASE_CLIENT_EMAIL
#   private_key     → FIREBASE_PRIVATE_KEY   (replace real line breaks with the literal \n)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
